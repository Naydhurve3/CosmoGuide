# ───────────────────────────────────────────────
#  CosmoGuide — Environment Configuration
# ───────────────────────────────────────────────
#
# API keys are best configured through CosmoGuide's built-in Settings
# Portal (click "Settings Portal" in the header, then "Configure Keys").
# Keys entered there are stored in your browser's localStorage and are
# sent directly to the AI provider via the server proxy.
#
# The variables below are OPTIONAL server-side fallbacks. They are used
# only when no key has been configured in the Settings Portal.
#
# ── Quick Start ──
# 1. Get a free Gemini API key: https://aistudio.google.com
# 2. Set GEMINI_API_KEY below (or skip this file and use the Settings Portal)
# 3. Run: npm install && npm run dev
# 4. Open http://localhost:3000
#

# Google Gemini API (Free tier available)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Groq API (Free tier available — fast Llama inference)
# GROQ_API_KEY="your_groq_key_here"

# OpenRouter API (Free models available)
# OPENROUTER_API_KEY="your_openrouter_key_here"

# Anthropic Claude API (Paid only)
# ANTHROPIC_API_KEY="your_anthropic_key_here"

# NVIDIA NIM API (Free tier available)
# NVIDIA_API_KEY="your_nvidia_key_here"

# Together AI (Free credits available)
# TOGETHER_API_KEY="your_together_key_here"

# DeepSeek API (Free tier available)
# DEEPSEEK_API_KEY="your_deepseek_key_here"

# Mistral AI (Free tier available)
# MISTRAL_API_KEY="your_mistral_key_here"

# Cohere API (Free tier available)
# COHERE_API_KEY="your_cohere_key_here"

# Perplexity API (Paid only)
# PERPLEXITY_API_KEY="your_perplexity_key_here"

# Hugging Face API (Free inference available)
# HUGGINGFACE_API_KEY="your_huggingface_key_here"

# The URL where this applet is deployed (optional, for production)
# APP_URL="http://localhost:3000"
